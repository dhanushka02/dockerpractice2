{
  "name": "pos-tool",
  "version": "1.0.0",
  "description": "Point of sale tool built with Node.js, Express, JavaScript, and PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
